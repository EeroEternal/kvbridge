# KVBridge Configuration

# Server
KVBRIDGE_HOST=0.0.0.0
KVBRIDGE_PORT=8001
KVBRIDGE_LOG_LEVEL=info

# Backend: vllm | sglang | mindie
KVBRIDGE_BACKEND=vllm
KVBRIDGE_BACKEND_URL=http://localhost:8000

# Model name exposed to clients
KVBRIDGE_MODEL_NAME=qwen3-coder

# Redis (leave empty to use in-memory fallback)
KVBRIDGE_REDIS_URL=redis://localhost:6379/0

# Session
KVBRIDGE_SESSION_TTL=3600
KVBRIDGE_MAX_CONTEXT_ROUNDS=3

# Delta Compression
KVBRIDGE_ENABLE_DELTA=true

# Prometheus
KVBRIDGE_METRICS_ENABLED=true
